<%- include('../partials/header.ejs') %>
    <main>
        <section class="addEmployee">
            <div class="container">
                <div class="row justify-content-center mt-3">
                    <div class="col-md-8">
                        <h1>Edit Employee</h1>
                        <form action="" method="post">
                            <div class="mb-3">
                                <label for="employeeName" class="form-label">Employee Name</label>
                                <input type="text" class="form-control" id="employeeName" name="employeeName"
                                    placeholder="Employee Name Here" value="<%= employee.employeeName %>" required
                                    disabled>
                            </div>
                            <div class="mb-3">
                                <label for="employeeRole" class="form-label">Employee Role</label>
                                <select class="form-select" name="employeeRole">
                                    <option name="employeeRole" disabled>Open this select menu</option>
                                    <option name="employeeRole" <%=employee.employeeRole==='Developer' ? 'selected' : ''
                                        %> value="Developer">Developer</option>
                                    <option name="employeeRole" <%=employee.employeeRole==='Manager' ? 'selected' : ''
                                        %> value="Manager">Manager</option>
                                    <option name="employeeRole" <%=employee.employeeRole==='HR' ? 'selected' : '' %>
                                        value="HR">HR</option>
                                    <option name="employeeRole" <%=employee.employeeRole==='Tester' ? 'selected' : '' %>
                                        value="Tester">Tester</option>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label for="employeeDepartment" class="form-label">Employee Department</label>
                                <select class="form-select" name="employeeDepartment">
                                    <option name="employeeDepartment" selected disabled>Open this select menu</option>
                                    <option name="employeeDepartment" <%=employee.employeeDepartment==='IT' ? 'selected'
                                        : '' %> value="IT">IT</option>
                                    <option name="employeeDepartment" <%=employee.employeeDepartment==='HR' ? 'selected'
                                        : '' %> value="HR">HR</option>
                                    <option name="employeeDepartment" <%=employee.employeeDepartment==='Sales'
                                        ? 'selected' : '' %> value="Sales">Sales</option>
                                    <option name="employeeDepartment" <%=employee.employeeDepartment==='Finance'
                                        ? 'selected' : '' %> value="Finance">Finance</option>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-check-label" for="exampleCheck1">Employee City</label>
                                <input type="text" class="form-control" id="employeeCity" name="employeeCity"
                                    placeholder="Employee City here" value="<% employee.employeeCity %>" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-check-label" for="exampleCheck1">Employee Salary</label>
                                <input type="number" class="form-control" id="employeeSalary" name="employeeSalary"
                                    placeholder="Employee Salary" value="<% employee.employeeSalary %>" required
                                    min="6000" max="1000000">
                            </div>
                            <div class="mb-3">
                                <label for="employeeExperience" class="form-label">Employee Experience</label>
                                <select class="form-select" name="employeeExperience">
                                    <option name="employeeExperience" selected disabled>Open this select menu</option>
                                    <option name="employeeExperience" <%=employee.employeeExperience==='1' ? 'selected'
                                        : '' %> value="1">1</option>
                                    <option name="employeeExperience" <%=employee.employeeExperience==='2' ? 'selected'
                                        : '' %> value="2">2</option>
                                    <option name="employeeExperience" <%=employee.employeeExperience==='3' ? 'selected'
                                        : '' %> value="3">3</option>
                                    <option name="employeeExperience" <%=employee.employeeExperience==='4' ? 'selected'
                                        : '' %> value="4">4</option>
                                    <option name="employeeExperience" <%=employee.employeeExperience==='5' ? 'selected'
                                        : '' %> value="5">5</option>
                                    <option name="employeeExperience" <%=employee.employeeExperience==='6' ? 'selected'
                                        : '' %> value="6">6+</option>
                                </select>
                            </div>
                            <button type="submit" class="btn btn-primary">Create Employee</button>
                        </form>
                    </div>
                </div>
            </div>
        </section>
    </main>
    <%- include('../partials/footer.ejs') %>