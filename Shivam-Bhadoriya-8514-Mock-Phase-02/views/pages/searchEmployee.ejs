<!doctype html>
<html lang="en">

<head>
    <title>Employee Management System</title>
    <!-- Required meta tags -->
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />

    <!-- Bootstrap CSS v5.2.1 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous" />
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-lg bg-body-tertiary">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" href="/">Employee Management</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                    aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse justify-content-between" id="navbarNav">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link active" aria-current="page" href="/">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/addEmployee">Add Employee</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/viewEmployee">View Employee</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/searchEmployee">Search Employees</a>
                        </li>
                        
                        <li class="nav-item">
                            <a class="nav-link" href="/filterEmployee">Filter Employees</a>
                        </li>
                    </ul>
                    <form class="d-flex" method="post" action="">
                        <input class="form-control me-2" type="search" placeholder="Enter Employee Name" name="employeeName" aria-label="Search" />
                        <button class="btn btn-outline-success" type="submit">Search</button>
                    </form>
                </div>
            </div>
        </nav>
    </header>
    <main>
        <section class="viewEmployee">
            <div class="container-fluid">
                <div class="row justify-content-center mt-3">
                    <% if(employee===[]) {%>
                        <div class="col-md-6 text-center mt-5">
                            <h2>No Employee Found</h2>
                            <p>Add Some Employees</p>
                            <a href="/addEmployee" class="btn btn-primary">Add Employees</a>
                        </div>
                        <% } else { %>
                            <div class="col-md-12">
                                <h1 class="mb-4">Employee Data</h1>
                                <table
                                    class="table table-hover table-active table-bordered table-success table-responsive table-striped table-striped-columns text-center">
                                    <thead>
                                        <tr>
                                            <th scope="col">Sr No.</th>
                                            <th scope="col">Employee Name</th>
                                            <th scope="col">Employee Role</th>
                                            <th scope="col">Employee Department</th>
                                            <th scope="col">Employee City</th>
                                            <th scope="col">Employee Salary In Rupees </th>
                                            <th scope="col">Employee Experience</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% employee.forEach((emp,index)=> { %>
                                            <tr>
                                                <td>
                                                    <%= index + 1 %>
                                                </td>
                                                <td>
                                                    <%= emp.employeeName %>
                                                </td>
                                                <td>
                                                    <%= emp.employeeRole %>
                                                </td>
                                                <td>
                                                    <%= emp.employeeDepartment %>
                                                </td>
                                                <td>
                                                    <%= emp.employeeCity %>
                                                </td>
                                                <td>
                                                    <%= emp.employeeSalary %>
                                                </td>
                                                <td>
                                                    <%= emp.employeeExperience %>
                                                </td>
                                            </tr>
                                        <% }); %>
                                    </tbody>
                                </table>
                            </div>
                            <% } %>
                </div>
            </div>
        </section>
    </main>
    <%- include('../partials/footer.ejs') %>